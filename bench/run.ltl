// bench/run.ltl — micro-benchmarks for ltl_chess_perft

import std::time
import std::io
use ltl_chess_perft as lib

fn measure(label: str, f: fn() -> ()) {
    let t0 = time::now_ns()
    f()
    let dt = time::now_ns() - t0
    io::println("{label}: {dt} ns")
}

fn main() {
    measure("load", fn() -> () { lib::main() })
}